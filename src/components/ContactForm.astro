---
// Form handler TBD — Cloudflare Pages Function or Formspree
---

<form class="contact-form" method="POST" action="/api/contact">
	<div class="form-group">
		<label for="name">Name</label>
		<input type="text" id="name" name="name" required />
	</div>
	<div class="form-group">
		<label for="email">Email</label>
		<input type="email" id="email" name="email" required />
	</div>
	<div class="form-group">
		<label for="phone">Phone <span class="optional">(optional)</span></label>
		<input type="tel" id="phone" name="phone" />
	</div>
	<div class="form-group">
		<label for="message">Message</label>
		<textarea id="message" name="message" rows="5" required></textarea>
	</div>
	<!-- Honeypot — real users leave this blank; bots fill everything -->
	<div class="contact-form__honeypot" aria-hidden="true">
		<label for="website">Website</label>
		<input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
	</div>
	<button type="submit" class="btn btn--primary">Send Message</button>
	<p class="contact-form__status" role="status" aria-live="polite"></p>
</form>

<script>
	const form = document.querySelector<HTMLFormElement>('.contact-form');
	const status = form?.querySelector<HTMLParagraphElement>('.contact-form__status');
	const button = form?.querySelector<HTMLButtonElement>('button[type="submit"]');

	form?.addEventListener('submit', async (e) => {
		e.preventDefault();
		if (!status || !button) return;

		status.textContent = 'Sending…';
		status.className = 'contact-form__status contact-form__status--pending';
		button.disabled = true;

		try {
			const res = await fetch('/api/contact', {
				method: 'POST',
				headers: { 'content-type': 'application/json' },
				body: JSON.stringify(Object.fromEntries(new FormData(form).entries())),
			});
			const data = await res.json().catch(() => ({}));
			if (res.ok && data.ok) {
				status.textContent = 'Thanks — your message is on its way. We will get back to you soon.';
				status.className = 'contact-form__status contact-form__status--ok';
				form.reset();
			} else {
				status.textContent = data.error || 'Something went wrong. Please try again.';
				status.className = 'contact-form__status contact-form__status--err';
			}
		} catch {
			status.textContent = 'Network error. Please check your connection and try again.';
			status.className = 'contact-form__status contact-form__status--err';
		} finally {
			button.disabled = false;
		}
	});
</script>

<style>
	.contact-form {
		max-width: 40rem;
	}

	.form-group {
		margin-bottom: var(--gap-m);
	}

	label {
		display: block;
		font-weight: 500;
		margin-bottom: 6px;
		color: var(--color-heading);
		font-size: var(--text-sm);
	}

	.optional {
		font-weight: 400;
		color: var(--color-text-muted);
		font-size: var(--text-xs);
	}

	input,
	textarea {
		width: 100%;
		padding: 12px 16px;
		border: 1px solid var(--color-border);
		font-family: var(--font-body);
		font-size: var(--text-base);
		color: var(--color-text);
		background: var(--color-bg);
		transition: border-color 0.2s var(--ease);
	}

	input:focus,
	textarea:focus {
		outline: none;
		border-color: var(--color-accent);
		box-shadow: 0 0 0 3px rgba(14, 145, 140, 0.1);
	}

	textarea {
		resize: vertical;
	}

	.contact-form__honeypot {
		position: absolute;
		left: -9999px;
		width: 1px;
		height: 1px;
		overflow: hidden;
	}

	.contact-form__status {
		margin-top: var(--gap-m);
		font-size: var(--text-sm);
		min-height: 1.5em;
	}
	.contact-form__status--pending { color: var(--color-text-muted); }
	.contact-form__status--ok      { color: var(--color-accent); font-weight: 500; }
	.contact-form__status--err     { color: #b00020; }
</style>
