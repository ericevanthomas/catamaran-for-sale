---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const allPages = await getCollection('pages');
const page = allPages.find((p) => p.id === 'about');
const { Content } = page ? await render(page) : { Content: null };
---

<BaseLayout
	title={page?.data.title ?? 'About Us — Voyage 500'}
	description={page?.data.description ?? 'Meet the family behind the Voyage 500.'}
>
	<section class="page-header">
		<div class="wrap">
			<p class="eyebrow">Voyage 500 · S/V Tropicalia</p>
			<h1>{page?.data.title ?? 'About Us'}</h1>
			<p class="page-header__sub">Meet the family behind the boat.</p>
		</div>
	</section>

	<section class="section">
		<div class="wrap">
			<div class="prose">
				{Content && <Content />}
			</div>
		</div>
	</section>

	<!-- PredictWind Location Widget -->
	<section class="section section--alt">
		<div class="wrap">
			<p class="eyebrow">Current Position</p>
			<h2>Where We Are Now</h2>
			<p class="widget-note">Tropicalia's live location via PredictWind.</p>
			<div class="predictwind-widget">
				<iframe src="https://forecast.predictwind.com/tracking/display/SV-Tropicalia/" width="100%" height="500" frameborder="0" loading="lazy" allow="geolocation"></iframe>
			</div>
		</div>
	</section>

	<section class="cta">
		<div class="wrap cta__inner">
			<h2>Want to know more?</h2>
			<p>We are happy to answer any questions about our time aboard, the boat's history, or anything else.</p>
			<a href="/contact/" class="btn btn--primary">Get in Touch</a>
		</div>
	</section>
</BaseLayout>

<style>
	.page-header {
		padding-top: 120px;
		padding-bottom: var(--gap-l);
		background: var(--color-bg-warm);
	}

	.page-header h1 {
		font-size: clamp(2.5rem, 4vw, 3.5rem);
		font-weight: 600;
		margin-top: var(--gap-s);
		margin-bottom: var(--gap-s);
	}

	.page-header__sub {
		font-size: var(--text-md);
		color: var(--color-text-muted);
		max-width: 50ch;
		margin: 0;
	}

	.wrap {
		max-width: 1280px;
		margin: 0 auto;
		padding-left: var(--gap-l);
		padding-right: var(--gap-l);
	}

	.section {
		padding: var(--space-3xl) 0;
	}

	.section--alt {
		background: var(--color-bg-warm);
	}

	.widget-note {
		color: var(--color-text-muted);
		margin-bottom: var(--space-lg);
	}

	.predictwind-widget {
		overflow: hidden;
		min-height: 400px;
		background: var(--color-bg);
	}

	.placeholder {
		padding: var(--space-2xl);
		text-align: center;
		color: var(--color-text-muted);
	}

	/* CTA */
	.cta {
		background: var(--color-bg-dark);
		padding: var(--size-12) 0;
	}

	.cta__inner {
		text-align: center;
	}

	.cta__inner h2 {
		color: #fff;
		font-weight: 600;
		margin-bottom: var(--gap-s);
	}

	.cta__inner p {
		color: rgba(255,255,255,0.4);
		font-size: var(--text-md);
		max-width: 45ch;
		margin: 0 auto var(--gap-m);
	}

	@media (max-width: 600px) {
		.wrap {
			padding-left: var(--gap-m);
			padding-right: var(--gap-m);
		}
		.page-header {
			padding-top: 80px;
		}
	}
</style>
