---
import BaseLayout from '../layouts/BaseLayout.astro';
import ResponsiveImage from '../components/ResponsiveImage.astro';
import { getCollection } from 'astro:content';
import { marked } from 'marked';

const md = (s?: string) => (s ? (marked.parseInline(s, { async: false }) as string) : '');

const allGallery = await getCollection('gallery');
const photos = allGallery
	.filter((p) => p.data.inGallery !== false)
	.sort((a, b) => a.data.order - b.data.order);

const categories = [...new Set(photos.map((p) => p.data.category).filter(Boolean))];

// Gallery columns at breakpoints: 4 → 3 → 2 → 1. On mobile, lie to the browser
// about the display size so it picks a smaller srcset variant (~400w instead
// of 800w) — the quality is still fine for a scrolling thumbnail view.
const GALLERY_SIZES = '(max-width: 600px) 50vw, (max-width: 900px) 40vw, (max-width: 1100px) 30vw, 23vw';
---

<BaseLayout title="Photos — 2010 Voyage 500 Catamaran For Sale By Owner" description="150+ photos of S/V Tropicalia, a 2010 Voyage 500 catamaran for sale by owner at $379,000. Exterior, salon, galley, cabins, systems, and sailing shots.">

	<section class="page-header">
		<div class="wrap">
			<p class="eyebrow">Voyage 500 · S/V Tropicalia</p>
			<h1>Photo Gallery</h1>
			<p class="page-header__sub">Browse all photos. Click any image to view full size.</p>
		</div>
	</section>

	{categories.length > 0 && (
		<nav class="filter">
			<div class="wrap filter__inner">
				<button class="filter__btn filter__btn--active" data-filter="all">All</button>
				{categories.map((cat) => (
					<button class="filter__btn" data-filter={cat}>{cat}</button>
				))}
			</div>
		</nav>
	)}

	<section class="gallery-section">
		<div class="wrap">
			<div class="gallery">
				{photos.map((photo, i) => (
					<figure class="gallery__item" data-category={photo.data.category} data-index={i}>
						<ResponsiveImage
							src={photo.data.image}
							alt={photo.data.alt}
							sizes={GALLERY_SIZES}
							loading={i < 4 ? 'eager' : 'lazy'}
							fetchpriority={i === 0 ? 'high' : undefined}
							decoding={i < 4 ? 'sync' : 'async'}
						/>
						{photo.data.caption && <figcaption class="gallery__caption" set:html={md(photo.data.caption)} />}
					</figure>
				))}
			</div>
		</div>
	</section>

	<!-- Lightbox -->
	<dialog class="lightbox" id="lightbox">
		<button class="lightbox__close" aria-label="Close">
			<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
		</button>
		<button class="lightbox__prev" aria-label="Previous">
			<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
		</button>
		<button class="lightbox__next" aria-label="Next">
			<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 6 15 12 9 18"/></svg>
		</button>
		<div class="lightbox__img-wrap">
			<img class="lightbox__img" src="" alt="" />
			<div class="lightbox__caption"></div>
		</div>
		<div class="lightbox__counter"></div>
	</dialog>

</BaseLayout>

<style>
	.wrap {
		max-width: 1280px;
		margin: 0 auto;
		padding-left: var(--gap-l);
		padding-right: var(--gap-l);
	}

	/* Page header */
	.page-header {
		padding-top: clamp(80px, 14vw, 120px);
		padding-bottom: var(--gap-l);
		background: var(--color-bg-warm);
	}

	.page-header h1 {
		font-size: clamp(2.5rem, 4vw, 3.5rem);
		font-weight: 600;
		margin-top: var(--gap-s);
		margin-bottom: var(--gap-s);
	}

	.page-header__sub {
		font-size: var(--text-md);
		color: var(--color-text-muted);
		margin: 0;
	}

	/* Filter — matches features page catnav */
	.filter {
		position: sticky;
		top: 72px;
		z-index: 90;
		background: rgba(250, 248, 245, 0.95);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--color-border-light);
	}

	.filter__inner {
		display: flex;
		gap: var(--gap-m);
		padding-top: 14px;
		padding-bottom: 14px;
		overflow-x: auto;
		scrollbar-width: none;
	}

	.filter__inner::-webkit-scrollbar { display: none; }

	.filter__btn {
		font-family: var(--font-body);
		font-size: var(--text-xs);
		font-weight: 500;
		color: var(--color-text-muted);
		background: none;
		border: none;
		padding: 0;
		padding-bottom: 2px;
		border-bottom: 2px solid transparent;
		cursor: pointer;
		white-space: nowrap;
		transition: color 0.2s;
	}

	.filter__btn:hover {
		color: var(--color-heading);
	}

	.filter__btn--active {
		color: var(--color-heading);
		font-weight: 600;
		border-bottom-color: var(--color-accent);
	}

	/* Gallery grid */
	.gallery-section {
		padding: var(--gap-l) 0 var(--size-12);
	}

	.gallery {
		display: flex;
		gap: 6px;
		align-items: flex-start;
	}

	.gallery__col {
		flex: 1 1 0;
		display: flex;
		flex-direction: column;
		gap: 6px;
		min-width: 0;
	}

	.gallery__item {
		margin: 0;
		width: 100%;
		overflow: hidden;
		cursor: pointer;
		position: relative;
	}

	.gallery__item[data-hidden] { display: none; }

	.gallery__item img {
		width: 100%;
		height: auto;
		display: block;
		transition: transform 0.4s var(--ease);
	}

	.gallery__caption {
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		margin: 0;
		padding: 24px 14px 12px;
		background: linear-gradient(to top, rgba(0, 0, 0, 0.78), rgba(0, 0, 0, 0));
		color: #fff;
		font-size: 0.8rem;
		line-height: 1.35;
		opacity: 0;
		transition: opacity 0.25s var(--ease);
		pointer-events: none;
	}

	.gallery__item:hover .gallery__caption,
	.gallery__item:focus-within .gallery__caption {
		opacity: 1;
	}

	.gallery__item:hover img {
		transform: scale(1.03);
	}

	/* Lightbox */
	.lightbox {
		position: fixed;
		inset: 0;
		border: none;
		background: rgba(0,0,0,0.95);
		padding: 0;
		width: 100vw;
		height: 100vh;
		max-width: 100vw;
		max-height: 100vh;
		z-index: 200;
	}

	.lightbox[open] {
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.lightbox::backdrop {
		background: rgba(0,0,0,0.95);
	}

	.lightbox__img-wrap {
		max-width: 90vw;
		max-height: 80vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
	}

	.lightbox__img {
		max-width: 100%;
		max-height: 80vh;
		object-fit: contain;
		user-select: none;
		-webkit-user-select: none;
		-webkit-user-drag: none;
		-webkit-tap-highlight-color: transparent;
		-webkit-touch-callout: none;
	}

	.lightbox,
	.lightbox * {
		-webkit-tap-highlight-color: transparent;
	}

	.lightbox__close {
		position: fixed;
		top: var(--gap-m);
		right: var(--gap-m);
		z-index: 10;
		width: 44px;
		height: 44px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(255,255,255,0.1);
		border: none;
		border-radius: 50%;
		cursor: pointer;
		color: #fff;
		transition: background 0.2s;
	}

	.lightbox__close:hover { background: rgba(255,255,255,0.2); }

	.lightbox__prev,
	.lightbox__next {
		position: fixed;
		top: 50%;
		transform: translateY(-50%);
		z-index: 10;
		width: 48px;
		height: 48px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(255,255,255,0.1);
		border: none;
		border-radius: 50%;
		cursor: pointer;
		color: #fff;
		transition: background 0.2s;
	}

	.lightbox__prev { left: var(--gap-m); }
	.lightbox__next { right: var(--gap-m); }
	.lightbox__prev:hover,
	.lightbox__next:hover { background: rgba(255,255,255,0.2); }

	.lightbox__caption {
		margin-top: 14px;
		padding: 0 var(--gap-m);
		color: rgba(255,255,255,0.92);
		font-size: var(--text-sm);
		line-height: 1.5;
		text-align: center;
		max-width: 80ch;
	}
	.lightbox__caption:empty { display: none; }

	.lightbox__counter {
		position: fixed;
		top: var(--gap-m);
		left: var(--gap-m);
		color: rgba(255,255,255,0.5);
		font-size: var(--text-sm);
		font-weight: 500;
	}

	/* Responsive */
	@media (max-width: 900px) {
		.filter { top: 72px; }
	}

	@media (max-width: 600px) {
		.wrap { padding-left: var(--gap-m); padding-right: var(--gap-m); }
		.page-header { padding-top: clamp(80px, 14vw, 120px); }
	}
</style>

<script>
	// Masonry: paint items in row-reading order across N columns.
	// CSS columns paint top-to-bottom, so humans read the order wrong —
	// use N flex columns and distribute items round-robin by index.
	const gallery = document.querySelector('.gallery') as HTMLElement;
	const items = document.querySelectorAll('.gallery__item');
	const allItems = Array.from(items) as HTMLElement[];

	function columnCount() {
		const w = window.innerWidth;
		if (w <= 600) return 1;
		if (w <= 900) return 2;
		if (w <= 1100) return 3;
		return 4;
	}

	let currentCols = 0;
	// Astro scopes styles with a data-astro-cid-* attribute. Since we create
	// the column divs in JS, we need to copy that attribute from the parent
	// so the scoped CSS (gap, flex-direction, etc.) actually applies.
	const scopeAttrs = Array.from(gallery.attributes).filter(a => a.name.startsWith('data-astro-cid-'));

	function layoutMasonry() {
		const n = columnCount();
		if (n === currentCols) return;
		currentCols = n;
		gallery.replaceChildren();
		const cols: HTMLElement[] = [];
		for (let i = 0; i < n; i++) {
			const c = document.createElement('div');
			c.className = 'gallery__col';
			for (const a of scopeAttrs) c.setAttribute(a.name, a.value);
			cols.push(c);
			gallery.appendChild(c);
		}
		allItems.forEach((item, i) => cols[i % n].appendChild(item));
	}

	layoutMasonry();
	let resizeTimer: ReturnType<typeof setTimeout>;
	window.addEventListener('resize', () => {
		clearTimeout(resizeTimer);
		resizeTimer = setTimeout(layoutMasonry, 120);
	});

	// Filter
	const filterBtns = document.querySelectorAll('.filter__btn');

	filterBtns.forEach(btn => {
		btn.addEventListener('click', () => {
			const filter = (btn as HTMLElement).dataset.filter;
			filterBtns.forEach(b => b.classList.remove('filter__btn--active'));
			btn.classList.add('filter__btn--active');
			items.forEach(item => {
				const cat = (item as HTMLElement).dataset.category;
				if (filter === 'all' || cat === filter) {
					(item as HTMLElement).removeAttribute('data-hidden');
				} else {
					(item as HTMLElement).setAttribute('data-hidden', '');
				}
			});
		});
	});

	// Lightbox
	const lightbox = document.getElementById('lightbox') as HTMLDialogElement;
	const lbImg = lightbox.querySelector('.lightbox__img') as HTMLImageElement;
	const lbCaption = lightbox.querySelector('.lightbox__caption') as HTMLElement;
	const lbCounter = lightbox.querySelector('.lightbox__counter') as HTMLElement;
	let currentIndex = 0;

	function getVisibleItems() {
		return allItems.filter(el => !(el as HTMLElement).hasAttribute('data-hidden'));
	}

	function showPhoto(index: number) {
		const visible = getVisibleItems();
		currentIndex = (index + visible.length) % visible.length;
		const item = visible[currentIndex];
		const img = item.querySelector('img') as HTMLImageElement;
		const caption = item.querySelector('figcaption');
		lbImg.src = img.dataset.full || img.currentSrc || img.src;
		lbImg.alt = img.alt;
		lbCaption.innerHTML = caption?.innerHTML || '';
		lbCounter.textContent = `${currentIndex + 1} / ${visible.length}`;
	}

	items.forEach(item => {
		item.addEventListener('click', () => {
			const visible = getVisibleItems();
			const idx = visible.indexOf(item);
			showPhoto(idx);
			lightbox.showModal();
		});
	});

	lightbox.querySelector('.lightbox__close')?.addEventListener('click', () => lightbox.close());
	lightbox.querySelector('.lightbox__prev')?.addEventListener('click', () => showPhoto(currentIndex - 1));
	lightbox.querySelector('.lightbox__next')?.addEventListener('click', () => showPhoto(currentIndex + 1));

	// Keyboard nav
	lightbox.addEventListener('keydown', (e) => {
		if (e.key === 'ArrowLeft') showPhoto(currentIndex - 1);
		if (e.key === 'ArrowRight') showPhoto(currentIndex + 1);
		if (e.key === 'Escape') lightbox.close();
	});

	// Close on backdrop
	lightbox.addEventListener('click', (e) => {
		if (e.target === lightbox) lightbox.close();
	});
</script>
