<style>
	.feat-row { text-decoration: none; color: inherit; }

	/* =============================================
	   HERO BADGE — rotating rope circle
	   ============================================= */
</style>

<script>
	// Photo lightbox
	const photoItems = document.querySelectorAll('.photos__item');
	const lightbox = document.getElementById('photo-lightbox') as HTMLDialogElement;
	const lbImg = lightbox.querySelector('.lightbox__img') as HTMLImageElement;
	const lbCounter = lightbox.querySelector('.lightbox__counter') as HTMLElement;
	const allPhotos = Array.from(photoItems);
	let currentIdx = 0;

	function showPhotoAt(idx: number) {
		currentIdx = (idx + allPhotos.length) % allPhotos.length;
		const img = allPhotos[currentIdx].querySelector('img') as HTMLImageElement;
		lbImg.src = img.src;
		lbImg.alt = img.alt;
		lbCounter.textContent = `${currentIdx + 1} / ${allPhotos.length}`;
	}

	photoItems.forEach((item, i) => {
		item.addEventListener('click', () => {
			showPhotoAt(i);
			lightbox.showModal();
		});
	});

	lightbox.querySelector('.lightbox__close')?.addEventListener('click', () => lightbox.close());
	lightbox.querySelector('.lightbox__prev')?.addEventListener('click', () => showPhotoAt(currentIdx - 1));
	lightbox.querySelector('.lightbox__next')?.addEventListener('click', () => showPhotoAt(currentIdx + 1));

	lightbox.addEventListener('keydown', (e) => {
		if (e.key === 'ArrowLeft') showPhotoAt(currentIdx - 1);
		if (e.key === 'ArrowRight') showPhotoAt(currentIdx + 1);
		if (e.key === 'Escape') lightbox.close();
	});

	lightbox.addEventListener('click', (e) => {
		if (e.target === lightbox) lightbox.close();
	});
</script>
