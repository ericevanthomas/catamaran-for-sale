---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allSpecs = await getCollection('specs');

const groupOrder = ['Dimensions', 'Engines & Propulsion', 'Tankage', 'Accommodations', 'Performance', 'Construction'];

const specsByGroup = allSpecs
	.sort((a, b) => a.data.order - b.data.order)
	.reduce((groups, spec) => {
		const group = spec.data.group;
		if (!groups[group]) groups[group] = [];
		groups[group].push(spec.data);
		return groups;
	}, {} as Record<string, Array<{ label: string; value: string }>>);

const sortedGroups = Object.entries(specsByGroup).sort(([a], [b]) => {
	const ai = groupOrder.indexOf(a);
	const bi = groupOrder.indexOf(b);
	return (ai === -1 ? 999 : ai) - (bi === -1 ? 999 : bi);
});
---

<BaseLayout title="Specifications & Equipment — Voyage 500 For Sale" description="Complete specifications and equipment inventory for the 2010 Voyage 500 catamaran S/V Tropicalia. Every system, every item, documented.">

	<section class="page-header">
		<div class="wrap">
			<p class="eyebrow">Voyage 500 · S/V Tropicalia</p>
			<h1>Specifications &amp; Equipment</h1>
			<p class="page-header__sub">Dimensions, tankage, propulsion, and the major equipment aboard.</p>
			<a href="/specs-sheet.pdf" class="btn btn--outline specs-download" download>
				<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
				Download Specifications Sheet
			</a>
		</div>
	</section>

	<!-- Quick-jump nav -->
	<nav class="s-jump">
		<div class="s-jump__inner">
			<a href="#specs">Specs</a>
			<a href="#interior">Interior</a>
			<a href="#master">Master Cabin</a>
			<a href="#guest">Guest Cabins</a>
			<a href="#galley">Galley</a>
			<a href="#deck">Deck</a>
			<a href="#electronics">Electronics</a>
			<a href="#ac-electrical">AC Electrical</a>
			<a href="#dc-electrical">DC Electrical</a>
			<a href="#plumbing">Plumbing</a>
			<a href="#safety">Safety</a>
		</div>
	</nav>

	<!-- SPECS TABLES -->
	<section class="s-specs" id="specs">
		<div class="wrap s-specs__inner">
			{sortedGroups.map(([group, specs]) => (
				<div class="s-specs__group">
					<h2 class="s-specs__group-title">{group}</h2>
					<table class="s-specs__table">
						<tbody>
							{specs.map((spec) => (
								<tr>
									<td class="s-specs__label">{spec.label}</td>
									<td class="s-specs__value">{spec.value}</td>
								</tr>
							))}
						</tbody>
					</table>
				</div>
			))}
		</div>
	</section>

	<!-- EQUIPMENT INVENTORY -->
	<section class="s-equip">
		<div class="wrap s-equip__inner">

			<!-- INTERIOR / SALON -->
