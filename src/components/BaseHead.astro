---
import '../styles/global.css';
import { SITE_URL, BOAT_NAME, BOAT_MODEL, BOAT_YEAR, BOAT_BUILDER, ASKING_PRICE } from '../consts';

interface Props {
	title: string;
	description: string;
	image?: string;
	schema?: Record<string, unknown>;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const { title, description, image, schema: extraSchema } = Astro.props;
const ogImageURL = image ? new URL(image, Astro.url) : new URL('/og-default.jpg', Astro.site);

// Product schema for the boat — emitted on every page.
const productSchema = {
	"@context": "https://schema.org",
	"@type": "Product",
	"@id": `${SITE_URL}#boat`,
	"name": `${BOAT_YEAR} ${BOAT_MODEL} Catamaran — ${BOAT_NAME}`,
	"alternateName": [`${BOAT_MODEL} Catamaran For Sale By Owner`, `${BOAT_YEAR} ${BOAT_MODEL}`],
	"description": "2010 Voyage 500 sailing catamaran for sale by owner. 50-foot 3-cabin owner's version with extensive 2025 upgrades — new saildrives, 1,280Ah lithium bank, Rainman watermaker, Raymarine Axiom and Evolution autopilot, and a new 6-person offshore life raft. Currently cruising the British Virgin Islands; arriving St. Augustine, FL June 1, 2026.",
	"url": SITE_URL,
	"image": ogImageURL.href,
	"brand": { "@type": "Brand", "name": BOAT_BUILDER },
	"manufacturer": { "@type": "Organization", "name": BOAT_BUILDER, "url": "https://www.voyageyachts.com/" },
	"model": BOAT_MODEL,
	"productionDate": BOAT_YEAR,
	"category": "Sailing Catamaran",
	"itemCondition": "https://schema.org/UsedCondition",
	"additionalProperty": [
		{ "@type": "PropertyValue", "name": "Length Overall", "value": "50 ft" },
		{ "@type": "PropertyValue", "name": "Beam", "value": "27 ft" },
		{ "@type": "PropertyValue", "name": "Draft", "value": "4 ft" },
		{ "@type": "PropertyValue", "name": "Displacement", "value": "22,708 lb" },
		{ "@type": "PropertyValue", "name": "Cabins", "value": "3 (Owner's Version)" },
		{ "@type": "PropertyValue", "name": "Heads", "value": "3" },
		{ "@type": "PropertyValue", "name": "Engines", "value": "Twin Yanmar 3JH5E, 39 hp each" },
		{ "@type": "PropertyValue", "name": "Fuel", "value": "Diesel — 212 gal" },
		{ "@type": "PropertyValue", "name": "Fresh Water", "value": "211 gal" },
		{ "@type": "PropertyValue", "name": "Hull Material", "value": "Hand-laid fiberglass" },
		{ "@type": "PropertyValue", "name": "Designer", "value": "Simonis Voogd" }
	],
	"offers": {
		"@type": "Offer",
		"priceCurrency": "USD",
		"price": ASKING_PRICE,
		"priceValidUntil": "2027-04-01",
		"availability": "https://schema.org/InStock",
		"itemCondition": "https://schema.org/UsedCondition",
		"businessFunction": "https://schema.org/Sell",
		"url": `${SITE_URL}/contact/`,
		"seller": {
			"@type": "Person",
			"name": "Eric Thomas",
			"url": `${SITE_URL}/about/`
		}
	}
};

// WebSite schema — helps Google understand the site and can enable sitelinks search box.
const websiteSchema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"@id": `${SITE_URL}#website`,
	"url": SITE_URL,
	"name": `${BOAT_MODEL} Catamaran For Sale — ${BOAT_NAME}`,
	"description": "Direct-from-owner listing for a 2010 Voyage 500 sailing catamaran.",
	"inLanguage": "en-US"
};
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="robots" content="follow, index, max-snippet:-1, max-video-preview:-1, max-image-preview:large" />
<!-- Preload the two critical font subsets (Cormorant 400 latin + Raleway 400 latin).
     Pulled out of the CSS @font-face chain so they fetch alongside the HTML. -->
<link rel="preload" href="/fonts/co3bmX5slCNuHLi8bLeY9MK7whWMhyjYqXtKky2F7g.woff2" as="font" type="font/woff2" crossorigin />
<link rel="preload" href="/fonts/1Ptug8zYS_SKggPNyC0IT4ttDfA.woff2" as="font" type="font/woff2" crossorigin />

<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32-v2.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16-v2.png" />
<link rel="icon" href="/favicon-v2.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon-v2.png" />
<link rel="manifest" href="/manifest.webmanifest" />
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Catamaran For Sale" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:image:secure_url" content={ogImageURL} />
<meta property="og:image:type" content="image/jpeg" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="2010 Voyage 500 sailing catamaran S/V Tropicalia at anchor in the British Virgin Islands" />
<meta property="og:locale" content="en_US" />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={ogImageURL} />

<!-- Schema.org — Product (the boat itself) -->
<script type="application/ld+json" set:html={JSON.stringify(productSchema)} />

<!-- Schema.org — WebSite -->
<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

<!-- Schema.org — Page-specific (FAQPage, BreadcrumbList, etc.) -->
{extraSchema && (
	<script type="application/ld+json" set:html={JSON.stringify(extraSchema)} />
)}
