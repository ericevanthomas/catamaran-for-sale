---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPages = await getCollection('pages');
const homepage = allPages.find((p) => p.id === 'homepage');

const allFeatures = await getCollection('features');
const featuredFeatures = allFeatures
	.filter((f) => f.data.featured)
	.sort((a, b) => a.data.order - b.data.order);

const title = 'Voyage 500 Catamaran For Sale by Owner';
const description = homepage?.data.description ?? '';
---

<BaseLayout title={title} description={description}>

	<!-- HERO — split screen -->
	<section class="hero">
		<div class="hero__text">
			<div class="hero__text-inner">
				<p class="eyebrow">2010 Voyage 500 · S/V Tropicalia</p>
				<h1>Voyage 500<br />Catamaran<br />For Sale</h1>
				<p class="hero__sub">{homepage?.data.priceDisplay}<br />{homepage?.data.locationDisplay}</p>
				<a href="/contact/" class="btn btn--primary">Inquire About This Boat</a>
			</div>
		</div>
		<div class="hero__image">
			<img src="/images/hero-bow-edited.webp" alt="Tropicalia — Voyage 500 catamaran bow in turquoise Caribbean water" fetchpriority="high" decoding="async" width="2000" height="2653" />
		</div>
	</section>

	<!-- AT A GLANCE -->
	<section class="glance">
		<div class="wrap">
			<div class="glance__grid">
				<div class="glance__item">
					<span class="glance__label">Year</span>
					<span class="glance__value">2010</span>
				</div>
				<div class="glance__item">
					<span class="glance__label">Length</span>
					<span class="glance__value">50 ft</span>
				</div>
				<div class="glance__item">
					<span class="glance__label">Asking Price</span>
					<span class="glance__value">$399,000</span>
				</div>
				<div class="glance__item">
					<span class="glance__label">Sale Type</span>
					<span class="glance__value">By Owner</span>
				</div>
				<div class="glance__item">
					<span class="glance__label">Layout</span>
					<span class="glance__value">3 Cabin Owner's Version</span>
				</div>
				<div class="glance__item">
					<span class="glance__label">Location</span>
					<span class="glance__value">US Virgin Islands</span>
				</div>
				<div class="glance__item">
					<span class="glance__label">New Batteries</span>
					<span class="glance__value">1,300Ah Lithium</span>
				</div>
				<div class="glance__item">
					<span class="glance__label">New Equipment</span>
					<span class="glance__value">Watermaker, chartplotter, life raft, safety gear</span>
				</div>
			</div>
			<div class="glance__footer">
				<p class="glance__note">Recent upgrades include new lithium batteries (1,300Ah), Rainman watermaker, Raymarine Axiom chartplotter, life raft, and all safety equipment.</p>
				<div class="glance__links">
					<a href="/specs/">Full Specs &amp; Equipment →</a>
				</div>
			</div>
		</div>
	</section>

	<!-- PHOTOS -->
	<section class="photos">
		<div class="photos__grid">
			<div class="photos__item photos__item--wide" data-photo-idx="0">
				<img src="/images/boat-full-starboard.webp" alt="Tropicalia at anchor, starboard view" loading="lazy" />
			</div>
			<div class="photos__item" data-photo-idx="1">
				<img src="/images/bow-crystal-water.webp" alt="Crystal clear water at the bow" loading="lazy" />
			</div>
			<div class="photos__item" data-photo-idx="2">
				<img src="/images/caribbean-anchorage.webp" alt="Caribbean anchorage at sunset" loading="lazy" />
			</div>
		</div>
		<div class="photos__footer">
			<a href="/gallery/" class="photos__more">View More Photos →</a>
		</div>
		<!-- Photo lightbox -->
		<dialog class="lightbox" id="photo-lightbox">
			<button class="lightbox__close" aria-label="Close">
				<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
			</button>
			<button class="lightbox__prev" aria-label="Previous">
				<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
			</button>
			<button class="lightbox__next" aria-label="Next">
				<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 6 15 12 9 18"/></svg>
			</button>
			<div class="lightbox__img-wrap">
				<img class="lightbox__img" src="" alt="" />
			</div>
			<div class="lightbox__counter"></div>
		</dialog>
	</section>

	<!-- WHY WE CHOSE THIS BOAT — intro -->
	<section class="features-intro">
		<div class="wrap">
			<div class="features-intro__grid">
				<div class="features-intro__text">
					<p class="eyebrow">From Our Family to Yours</p>
					<h2>Why we chose this boat.</h2>
					<p>We spent a year searching for the right catamaran before we found Tropicalia. The Voyage 500 checked every box: the spacious 3-cabin Owner's Version layout, the proven Simonis Voogd hull design, and the fact that she was the last 500 ever built by the Voyage factory. Her original owner was an aerospace engineer who ensured she was built to the highest standard. Here are a few of the things that made us fall in love with her.</p>
				</div>
				<div class="features-intro__photo">
					<img src="/images/kids-cockpit.webp" alt="Our family aboard Tropicalia" loading="lazy" />
				</div>
			</div>
		</div>
	</section>

	<!-- FEATURED FEATURES — full-bleed alternating -->
	{featuredFeatures.map((feature, i) => (
		<section class:list={['feat-row', { 'feat-row--reverse': i % 2 === 1 }]}>
			<div class="feat-row__image">
				<img src={feature.data.photos?.[0] || ''} alt={feature.data.title} loading="lazy" />
			</div>
			<div class="feat-row__content">
				<div class="feat-row__inner">
					{feature.data.category && <span class="card__cat">{feature.data.category}</span>}
					<h3>{feature.data.title}</h3>
					<p>{feature.data.description}</p>
					<a href="/features/" class="card__more">Learn more →</a>
				</div>
			</div>
		</section>
	))}

	<section class="features-cta">
		<div class="wrap" style="text-align: center; padding-top: var(--gap-l); padding-bottom: var(--gap-l);">
			<a href="/features/" class="btn btn--outline">View All Features &amp; Systems</a>
		</div>
	</section>

	<!-- RECENT UPGRADES — dark -->
	<section class="upgrades">
		<div class="wrap">
			<p class="upgrades__eyebrow">Installed by Current Owners</p>
			<h2 class="upgrades__heading">Recent Upgrades</h2>
			<div class="upgrades__grid">
				<div class="upgrades__item">
					<svg class="upgrades__icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
					<h3>New 1,300Ah Lithium Battery Bank</h3>
					<p>Upgraded LiFePO4 house bank for full energy independence at anchor.</p>
				</div>
				<div class="upgrades__item">
					<svg class="upgrades__icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>
					<h3>New Rainman Watermaker</h3>
					<p>Fresh water independence anywhere you anchor. No marina dependency.</p>
				</div>
				<div class="upgrades__item">
					<svg class="upgrades__icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
					<h3>New Raymarine Axiom Chartplotter</h3>
					<p>Full Caribbean and North America cartography.</p>
				</div>
				<div class="upgrades__item">
					<svg class="upgrades__icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
					<h3>New Life Raft &amp; Safety Gear</h3>
					<p>New EPIRB, ditch bag, personal beacons, and current flares.</p>
				</div>
				<div class="upgrades__item">
					<svg class="upgrades__icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/></svg>
					<h3>New Victron Inverter/Charger</h3>
					<p>3000W Victron with Cerbo GX monitoring, installed 2024.</p>
				</div>
				<div class="upgrades__item">
					<svg class="upgrades__icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>
					<h3>New Starlink Internet</h3>
					<p>Reliable broadband connectivity throughout the Caribbean.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- KEY EQUIPMENT — what cruisers look for -->
	{homepage?.data.highlightsBullets && (
		<section class="highlights">
			<div class="wrap">
				<div class="highlights__header">
					<p class="eyebrow">Cruise-Ready</p>
					<h2>Key Equipment</h2>
				</div>
				<div class="highlights__grid">
					{homepage.data.highlightsBullets.map((bullet: string) => (
						<div class="highlights__item">
							<svg class="highlights__check" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
							<span>{bullet}</span>
						</div>
					))}
				</div>
			</div>
		</section>
	)}

	<!-- FULL PHOTO -->
	<section class="fullphoto">
		<img src="/images/aerial-1.webp" alt="Aerial view of Tropicalia at anchor" loading="lazy" />
	</section>

	<!-- CTA — dark -->
	<section class="cta">
		<div class="wrap cta__inner">
			<h2>Buy Direct from<br />the Owner</h2>
			<p>No brokers, no commissions, no middlemen. You deal directly with the people who know this boat inside and out. We will answer every question honestly and make the process straightforward.</p>
			<div class="cta__buttons">
				<a href="/contact/" class="btn btn--primary">Get in Touch</a>
				<a href="/transaction/" class="btn btn--outline cta__outline">How Does a FSBO Sale Work?</a>
			</div>
		</div>
	</section>

</BaseLayout>

<style>
	/* =============================================
	   LAYOUT
	   ============================================= */
	.wrap {
		max-width: 1280px;
		margin: 0 auto;
		padding-left: var(--gap-l);
		padding-right: var(--gap-l);
	}

	/* =============================================
	   HERO — split screen
	   ============================================= */
	.hero {
		display: grid;
		grid-template-columns: 1fr 1fr;
		min-height: 100vh;
		max-height: 960px;
	}

	.hero__text {
		display: flex;
		align-items: center;
		padding: var(--size-12) var(--gap-l);
		background: var(--color-bg);
	}

	.hero__text-inner {
		max-width: 480px;
	}

	.hero__text h1 {
		font-size: clamp(2.8rem, 4.5vw, 4.2rem);
		font-weight: 600;
		line-height: 1;
		letter-spacing: -1px;
		margin: var(--gap-s) 0 var(--gap-m);
	}

	.hero__sub {
		font-size: var(--text-md);
		color: var(--color-text-muted);
		line-height: 1.6;
		margin-bottom: var(--gap-m);
	}

	.hero__image {
		overflow: hidden;
		position: relative;
	}

	.hero__image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	/* =============================================
	   AT A GLANCE
	   ============================================= */
	.glance {
		padding: var(--gap-l) 0;
		background: var(--color-bg-warm);
	}

	.glance__grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		border-top: 1px solid var(--color-border);
		border-left: 1px solid var(--color-border);
	}

	.glance__item {
		padding: var(--size-4);
		border-bottom: 1px solid var(--color-border);
		border-right: 1px solid var(--color-border);
	}

	.glance__label {
		display: block;
		font-size: var(--text-xs);
		font-weight: 500;
		color: var(--color-text-muted);
		text-transform: uppercase;
		letter-spacing: 1px;
		margin-bottom: 4px;
	}

	.glance__value {
		display: block;
		font-family: var(--font-display);
		font-size: var(--text-lg);
		font-weight: 600;
		color: var(--color-heading);
		line-height: 1.3;
	}

	.glance__footer {
		margin-top: var(--gap-l);
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		gap: var(--gap-l);
	}

	.glance__note {
		font-size: var(--text-sm);
		color: var(--color-text-muted);
		line-height: 1.6;
		max-width: 55ch;
		margin: 0;
	}

	.glance__links {
		display: flex;
		gap: var(--gap-m);
		flex-shrink: 0;
	}

	.glance__links a {
		font-size: var(--text-sm);
		font-weight: 600;
		color: var(--color-accent);
		white-space: nowrap;
	}

	/* =============================================
	   PHOTOS
	   ============================================= */
	.photos {
		padding: 0;
	}

	.photos__grid {
		display: grid;
		grid-template-columns: 1.2fr 1fr 1fr;
		gap: 2px;
	}

	.photos__item {
		overflow: hidden;
	}

	.photos__item img {
		width: 100%;
		height: 380px;
		object-fit: cover;
		transition: transform 0.5s var(--ease);
	}

	.photos__item {
		cursor: pointer;
	}

	.photos__item:hover img {
		transform: scale(1.03);
	}

	.photos__footer {
		text-align: right;
		padding: var(--gap-s) var(--gap-l) 0;
	}

	.photos__more {
		font-size: var(--text-sm);
		font-weight: 600;
		color: var(--color-accent);
	}

	/* Lightbox */
	.lightbox {
		border: none;
		background: rgba(0,0,0,0.95);
		padding: 0;
		max-width: 100vw;
		max-height: 100vh;
		z-index: 200;
	}

	.lightbox[open] {
		position: fixed;
		inset: 0;
		width: 100vw;
		height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.lightbox::backdrop { background: rgba(0,0,0,0.95); }

	.lightbox__img-wrap {
		max-width: 90vw;
		max-height: 85vh;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.lightbox__img {
		max-width: 100%;
		max-height: 85vh;
		object-fit: contain;
	}

	.lightbox__close,
	.lightbox__prev,
	.lightbox__next {
		position: fixed;
		z-index: 10;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(255,255,255,0.1);
		border: none;
		border-radius: 50%;
		cursor: pointer;
		color: #fff;
		transition: background 0.2s;
	}

	.lightbox__close { top: var(--gap-m); right: var(--gap-m); width: 44px; height: 44px; }
	.lightbox__prev, .lightbox__next { top: 50%; transform: translateY(-50%); width: 48px; height: 48px; }
	.lightbox__prev { left: var(--gap-m); }
	.lightbox__next { right: var(--gap-m); }
	.lightbox__close:hover, .lightbox__prev:hover, .lightbox__next:hover { background: rgba(255,255,255,0.2); }

	.lightbox__counter {
		position: fixed;
		top: var(--gap-m);
		left: var(--gap-m);
		color: rgba(255,255,255,0.5);
		font-size: var(--text-sm);
		font-weight: 500;
	}

	/* =============================================
	   FEATURES INTRO — warm bg
	   ============================================= */
	.features-intro {
		padding: var(--size-11) 0;
		background: var(--color-bg-warm);
	}

	.features-intro__grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--gap-l);
		align-items: center;
	}

	.features-intro__text h2 {
		font-size: clamp(2rem, 3vw, 2.6rem);
		font-weight: 600;
		margin: var(--gap-s) 0 var(--gap-m);
	}

	.features-intro__text p {
		font-size: var(--text-md);
		color: var(--color-text-muted);
		line-height: 1.75;
		max-width: 45ch;
	}

	.features-intro__photo {
		overflow: hidden;
	}

	.features-intro__photo img {
		width: 100%;
		aspect-ratio: 4/3;
		object-fit: cover;
	}

	/* =============================================
	   FEATURED ROWS — full-bleed alternating
	   ============================================= */
	.feat-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		min-height: 500px;
	}

	.feat-row--reverse {
		direction: rtl;
	}

	.feat-row--reverse > * {
		direction: ltr;
	}

	.feat-row__image {
		overflow: hidden;
	}

	.feat-row__image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s var(--ease);
	}

	.feat-row:hover .feat-row__image img {
		transform: scale(1.03);
	}

	.feat-row__content {
		display: flex;
		align-items: center;
		padding: var(--size-11) var(--gap-l);
	}

	.feat-row--reverse .feat-row__content {
		justify-content: flex-end;
	}

	.feat-row__inner {
		max-width: 480px;
	}

	.feat-row__inner h3 {
		font-size: clamp(1.8rem, 2.5vw, 2.4rem);
		font-weight: 600;
		margin: var(--gap-s) 0 var(--gap-m);
		line-height: 1.15;
	}

	.feat-row__inner p {
		font-size: var(--text-md);
		color: var(--color-text-muted);
		line-height: 1.7;
		margin-bottom: var(--gap-m);
	}

	.card__cat {
		font-size: var(--text-xs);
		font-weight: 500;
		color: var(--color-text-muted);
		text-transform: uppercase;
		letter-spacing: 1px;
	}

	.card__more {
		font-size: var(--text-sm);
		font-weight: 600;
		color: var(--color-accent);
		text-decoration: none;
	}

	.features-cta {
		background: var(--color-bg-warm);
	}

	/* =============================================
	   UPGRADES — dark
	   ============================================= */
	.upgrades {
		background: var(--color-bg-dark);
		padding: var(--size-11) 0;
	}

	.upgrades__eyebrow {
		font-family: var(--font-body);
		font-size: var(--text-xs);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 2.5px;
		color: var(--color-accent-light);
		margin-bottom: var(--gap-s);
	}

	.upgrades__heading {
		color: #fff;
		font-weight: 600;
		margin-bottom: var(--gap-l);
	}

	.upgrades__grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--gap-l);
	}

	.upgrades__icon {
		color: var(--color-accent-light);
		margin-bottom: var(--gap-s);
	}

	.upgrades__item h3 {
		font-size: var(--text-xl);
		font-weight: 600;
		color: #fff;
		margin-bottom: 6px;
	}

	.upgrades__item p {
		font-size: var(--text-sm);
		color: rgba(255,255,255,0.45);
		line-height: 1.6;
		margin: 0;
	}

	/* =============================================
	   HIGHLIGHTS
	   ============================================= */
	.highlights {
		padding: var(--size-11) 0;
	}

	.highlights__header h2 {
		font-weight: 600;
		margin-top: var(--gap-s);
		margin-bottom: var(--gap-l);
	}

	.highlights__grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--gap-s) var(--gap-l);
	}

	.highlights__item {
		display: flex;
		align-items: flex-start;
		gap: 10px;
		padding: 14px 0;
		border-bottom: 1px solid var(--color-border-light);
		font-size: var(--text-sm);
		color: var(--color-text);
		line-height: 1.5;
	}

	.highlights__check {
		color: var(--color-accent);
		flex-shrink: 0;
		margin-top: 1px;
	}

	/* =============================================
	   FULL PHOTO
	   ============================================= */
	.fullphoto {
		line-height: 0;
	}

	.fullphoto img {
		width: 100%;
		height: 500px;
		object-fit: cover;
	}

	/* =============================================
	   CTA — dark
	   ============================================= */
	.cta {
		background: var(--color-bg-dark);
		padding: var(--size-12) 0;
	}

	.cta__inner {
		text-align: center;
	}

	.cta__inner h2 {
		font-size: clamp(2.5rem, 4.5vw, 3.8rem);
		font-weight: 600;
		color: #fff;
		line-height: 1.05;
		margin-bottom: var(--space-md);
	}

