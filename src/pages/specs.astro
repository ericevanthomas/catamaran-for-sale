	<section class="s-cta-link">
		<div class="wrap s-cta-link__inner">
			<p>For photos, videos, and detailed write-ups on each system, see the Features page.</p>
			<a href="/features/" class="btn btn--primary">View Features &amp; Systems</a>
		</div>
	</section>

</BaseLayout>

<style>
	.wrap {
		max-width: 1280px;
		margin: 0 auto;
		padding-left: var(--gap-l);
		padding-right: var(--gap-l);
	}

	.page-header {
		padding-top: 120px;
		padding-bottom: var(--gap-l);
		background: var(--color-bg-warm);
	}

	.page-header h1 {
		font-size: clamp(2.5rem, 4vw, 3.5rem);
		font-weight: 600;
		margin-top: var(--gap-s);
		margin-bottom: var(--gap-s);
	}

	.page-header__sub {
		font-size: var(--text-md);
		color: var(--color-text-muted);
		max-width: 60ch;
		margin: 0;
	}

	/* =============================================
	   JUMP NAV
	   ============================================= */
	.s-jump {
		position: sticky;
		top: 0;
		z-index: 50;
		background: rgba(255,255,255,0.92);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border-bottom: 1px solid var(--color-border-light);
	}

	.s-jump__inner {
		max-width: 1280px;
		margin: 0 auto;
		padding: 14px var(--gap-l);
		-webkit-overflow-scrolling: touch;
		display: flex;
		gap: 24px;
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
		scrollbar-width: none;
	}

	.s-jump__inner::-webkit-scrollbar {
		display: none;
	}

	.s-jump__inner a {
		font-family: var(--font-body);
		font-size: var(--text-xs);
		font-weight: 500;
		color: var(--color-text-muted);
		text-decoration: none;
		white-space: nowrap;
		transition: color 0.2s;
	}

	.s-jump__inner a:hover {
		color: var(--color-heading);
	}

	/* =============================================
	   SPECS TABLES
	   ============================================= */
	.s-specs {
		padding: var(--gap-l) 0;
	}

	.s-specs__inner {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--gap-m);
	}

	.s-specs__group {
		background: var(--color-bg);
		border: 1px solid var(--color-border-light);
		overflow: hidden;
	}

	.s-specs__group-title {
		font-family: var(--font-display);
		font-size: var(--text-xl);
		font-weight: 600;
		color: var(--color-heading);
		padding: var(--gap-m);
		margin: 0;
		border-bottom: 2px solid var(--color-accent);
	}

	.s-specs__table {
		width: 100%;
		border-collapse: collapse;
	}

	.s-specs__table tr {
		border-bottom: 1px solid var(--color-border-light);
	}

	.s-specs__table tr:last-child {
		border-bottom: none;
	}

	.s-specs__label {
		padding: 12px var(--gap-m);
		font-size: var(--text-sm);
		color: var(--color-text-muted);
		font-weight: 500;
		width: 40%;
		vertical-align: top;
	}

	.s-specs__value {
		padding: 12px var(--gap-m);
		font-size: var(--text-sm);
		color: var(--color-heading);
		font-weight: 600;
	}

	/* =============================================
	   EQUIPMENT LISTS
	   ============================================= */
	.s-equip {
		padding: 0;
	}

	.s-equip__section {
		padding: var(--space-2xl) 0;
		border-bottom: 1px solid var(--color-border-light);
	}

	.s-equip__section:last-child {
		border-bottom: none;
	}

	.s-equip__section h2 {
		font-size: clamp(1.6rem, 2.5vw, 2rem);
		font-weight: 600;
		margin-bottom: var(--space-sm);
	}

	.s-equip__section h3 {
		font-size: var(--text-xl);
		font-weight: 600;
		margin-top: var(--space-xl);
		margin-bottom: var(--space-sm);
	}

	.s-equip__note {
		font-size: var(--text-sm);
		color: var(--color-text-muted);
		font-style: italic;
		margin-bottom: var(--space-lg);
		max-width: 70ch;
	}

	.s-equip__section ul {
		list-style: none;
		padding: 0;
		margin: 0;
		columns: 2;
		column-gap: var(--space-2xl);
	}

	.s-equip__section li {
		padding: 10px 0 10px 20px;
		position: relative;
		break-inside: avoid;
		font-size: var(--text-sm);
		color: var(--color-text);
		line-height: 1.5;
		border-bottom: 1px solid var(--color-border-light);
	}

	.s-equip__section li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 17px;
		width: 5px;
		height: 5px;
		border-radius: 50%;
		background: var(--color-accent);
	}

	/* Item badges */
	.s-equip__badge {
		display: inline-block;
		font-family: var(--font-body);
		font-size: 0.6rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 1px;
		padding: 2px 8px;
		border-radius: 100px;
		margin-left: 8px;
		vertical-align: middle;
	}

	.s-equip__badge--new {
		background: var(--color-accent);
		color: #fff;
	}

	.s-equip__badge--upgraded {
		background: var(--color-gold);
		color: #fff;
	}

	.specs-download {
		margin-top: var(--gap-m);
		display: inline-flex;
		align-items: center;
		gap: 8px;
	}

	.specs-download svg {
		flex-shrink: 0;
	}

	/* =============================================
	   CTA LINK
	   ============================================= */
	.s-cta-link {
		padding: var(--gap-l) 0;
	}

	.s-cta-link__inner {
		background: var(--color-bg-warm);
		padding: 60px;
		text-align: center;
	}

	.s-cta-link__inner p {
		font-size: var(--text-md);
		color: var(--color-text-muted);
		margin-bottom: var(--space-lg);
	}

	/* =============================================
	   RESPONSIVE
	   ============================================= */
	@media (max-width: 768px) {
		.s-page-header {
			padding-top: 100px;
			padding-bottom: 40px;
		}

		.s-specs__inner {
			grid-template-columns: 1fr;
		}

		.s-equip__section ul {
			columns: 1;
		}

		.s-cta-link__inner {
			padding: 40px 24px;
		}
	}
</style>
