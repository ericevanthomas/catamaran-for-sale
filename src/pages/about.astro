---
import BaseLayout from '../layouts/BaseLayout.astro';
import ResponsiveImage from '../components/ResponsiveImage.astro';
import { getCollection, render } from 'astro:content';

const allPages = await getCollection('pages');
const page = allPages.find((p) => p.id === 'about');
const { Content } = page ? await render(page) : { Content: null };
---

<BaseLayout
	title={page?.data.title ?? 'About Us — Voyage 500'}
	description={page?.data.description ?? 'The family behind the Voyage 500.'}
>

	<section class="about-hero">
		<div class="wrap about-hero__grid">
			<figure class="about-hero__photo">
				<ResponsiveImage
					src="/images/about/family.webp"
					alt="Eric, Alex, Leon, and Margot on a rocky shore in the British Virgin Islands"
					sizes="(min-width: 900px) 480px, 100vw"
					loading="eager"
					fetchpriority="high"
				/>
			</figure>
			<div class="about-hero__text">
				<p class="eyebrow">Voyage 500 · S/V Tropicalia</p>
				<h1>About us</h1>
				<div class="prose">
					{Content && <Content />}
				</div>
			</div>
		</div>
	</section>

	<section class="section section--alt">
		<div class="wrap">
			<p class="eyebrow">Current Position</p>
			<h2>Where we are now</h2>
			<p class="widget-note">Tropicalia's live location via Predictwind.</p>
			<div class="predictwind-widget">
				<iframe src="https://forecast.predictwind.com/tracking/display/SV-Tropicalia/" width="100%" height="500" frameborder="0" loading="lazy" allow="geolocation"></iframe>
			</div>
		</div>
	</section>

	<section class="cta">
		<div class="wrap cta__inner">
			<h2>Want to know more?</h2>
			<p>Happy to answer any questions about our time aboard, the boat's history, or anything else.</p>
			<a href="/contact/" class="btn btn--primary">Get in Touch</a>
		</div>
	</section>
</BaseLayout>

<style>
	.wrap {
		max-width: 1280px;
		margin: 0 auto;
		padding-left: var(--gap-l);
		padding-right: var(--gap-l);
	}

	/* HERO — portrait photo + text, two columns */
	.about-hero {
		padding-top: 120px;
		padding-bottom: var(--space-3xl);
		background: var(--color-bg-warm);
	}

	.about-hero__grid {
		display: grid;
		grid-template-columns: 1fr 1.2fr;
		gap: clamp(var(--gap-l), 6vw, 88px);
		align-items: start;
	}

	.about-hero__photo {
		margin: 0;
		position: sticky;
		top: 100px;
	}

	.about-hero__photo img {
		width: 100%;
		height: auto;
		display: block;
		border-radius: 6px;
		box-shadow: 0 18px 40px -20px rgba(10, 25, 40, 0.35);
	}

	.about-hero__text h1 {
		font-size: clamp(2.25rem, 3.5vw, 3rem);
		font-weight: 600;
		margin: var(--gap-s) 0 var(--gap-m);
		letter-spacing: -0.01em;
	}

	.about-hero__text .prose :global(p) {
		font-size: var(--text-md);
		line-height: 1.75;
		color: var(--color-text);
		margin: 0 0 var(--gap-m);
		max-width: 58ch;
	}

	.about-hero__text .prose :global(p:last-child) {
		margin-bottom: 0;
	}

	.about-hero__text .prose :global(a) {
		color: var(--color-accent);
		text-decoration: underline;
		text-underline-offset: 3px;
		text-decoration-thickness: 1px;
	}

	/* Location widget */
	.section {
		padding: var(--space-3xl) 0;
	}
	.section--alt { background: var(--color-bg); }

	.widget-note {
		color: var(--color-text-muted);
		margin-bottom: var(--gap-m);
	}

	.predictwind-widget {
		overflow: hidden;
		min-height: 400px;
		background: var(--color-bg);
		border-radius: 4px;
	}

	/* CTA */
	.cta {
		background: var(--color-bg-dark);
		padding: var(--size-12) 0;
	}
	.cta__inner { text-align: center; }
	.cta__inner h2 {
		color: #fff;
		font-weight: 600;
		margin-bottom: var(--gap-s);
	}
	.cta__inner p {
		color: rgba(255, 255, 255, 0.5);
		font-size: var(--text-md);
		max-width: 45ch;
		margin: 0 auto var(--gap-m);
	}

	@media (max-width: 900px) {
		.about-hero {
			padding-top: 96px;
		}
		.about-hero__grid {
			grid-template-columns: 1fr;
			gap: var(--gap-l);
		}
		.about-hero__photo {
			position: static;
			max-width: 460px;
			margin: 0 auto;
		}
	}

	@media (max-width: 600px) {
		.wrap {
			padding-left: var(--gap-m);
			padding-right: var(--gap-m);
		}
		.about-hero { padding-top: 80px; }
	}
</style>
