---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { marked } from 'marked';

const allPages = await getCollection('pages');
const page = allPages.find((p) => p.id === 'transaction');
const body = page?.body ?? '';

// Parse the markdown into: leading intro paragraphs, numbered steps (## N. Title),
// and trailing non-numbered sections. Numbered headings become timeline items.
type Section = { heading: string; body: string; num?: number };
const sections: Section[] = [];
let current: Section | null = null;
for (const line of body.split('\n')) {
	const h2 = line.match(/^##\s+(.+)$/);
	if (h2) {
		if (current) sections.push(current);
		const title = h2[1];
		const numMatch = title.match(/^(\d+)\.\s+(.+)$/);
		current = numMatch
			? { heading: numMatch[2], body: '', num: parseInt(numMatch[1], 10) }
			: { heading: title, body: '' };
	} else if (current) {
		current.body += line + '\n';
	}
}
if (current) sections.push(current);

const steps = sections.filter((s) => typeof s.num === 'number') as Required<Section>[];
const leading = sections.find((s) => s.num === undefined);
const trailing = sections.filter((s) => s.num === undefined && s !== leading);

const mdBlock = (s: string) => marked.parse(s, { async: false }) as string;
---

<BaseLayout
	title={page?.data.title ?? 'How the Sale Works — Voyage 500'}
	description={page?.data.description ?? 'How the purchase process works.'}
>
	<section class="page-header">
		<div class="wrap">
			<h1 class="eyebrow page-header__h1">Voyage 500 Catamaran For Sale</h1>
			<p class="page-title">How the Sale Works</p>
		</div>
	</section>

	<section class="status-callout" id="sale-pending">
		<div class="wrap">
			<div class="status-callout__inner">
				<div class="status-callout__badge">
					<span class="status-callout__dot" aria-hidden="true"></span>
					<span class="status-callout__label">Current Status</span>
				</div>
				<h2 class="status-callout__title">Sale Pending</h2>
				<p class="status-callout__body">
					<em>Tropicalia</em> is currently under contract. The buyer has signed a purchase &amp; sale agreement, and we are moving through the survey, sea trial, and closing process described below.
				</p>
				<p class="status-callout__body status-callout__body--soft">
					You are still welcome to <a href="/contact/">reach out</a> with questions or to express interest &mdash; we are happy to keep your information on file and let you know if anything changes.
				</p>
			</div>
		</div>
	</section>

	{leading && (
		<section class="transaction-intro">
			<div class="wrap">
				<div class="transaction-intro__inner">
					<h2>{leading.heading}</h2>
					<div class="prose" set:html={mdBlock(leading.body.trim())} />
				</div>
			</div>
		</section>
	)}

	<section class="timeline-section">
		<div class="wrap">
			<ol class="timeline" id="timeline">
				{steps.map((step) => (
					<li class="timeline__step">
						<div class="timeline__marker">
							<span class="timeline__dot">{step.num}</span>
						</div>
						<div class="timeline__card">
							<h3 class="timeline__title">{step.heading}</h3>
							<div class="prose" set:html={mdBlock(step.body.trim())} />
						</div>
					</li>
				))}
			</ol>
		</div>
	</section>

	{trailing.length > 0 && (
		<section class="transaction-outro">
			<div class="wrap transaction-outro__wrap">
				{trailing.map((t) => {
					const isFull = t.body.includes('forms-grid');
					return (
						<div class:list={['transaction-outro__item', { 'transaction-outro__item--full': isFull }]}>
							<h2>{t.heading}</h2>
							<div class="prose" set:html={mdBlock(t.body.trim())} />
						</div>
					);
				})}
			</div>
		</section>
	)}

	<section class="cta">
		<div class="wrap cta__inner">
			<h2>Ready to get started?</h2>
			<p>Reach out anytime. We are happy to answer questions, share additional photos, or set up a video walkthrough.</p>
			<a href="/contact/" class="btn btn--primary">Contact Us</a>
		</div>
	</section>
</BaseLayout>

<style>
	.wrap {
		max-width: 1280px;
		margin: 0 auto;
		padding-left: var(--gap-l);
		padding-right: var(--gap-l);
	}

	.page-header {
		padding-top: clamp(80px, 14vw, 120px);
		padding-bottom: var(--gap-l);
		background: var(--color-bg-warm);
	}
	.page-header__h1 {
		display: block;
		margin: 0;
	}
	.page-title {
		font-family: var(--font-display);
		font-size: clamp(2.5rem, 4vw, 3.5rem);
		font-weight: 600;
		color: var(--color-heading);
		line-height: 1.15;
		letter-spacing: -0.01em;
		margin-top: var(--gap-s);
		margin-bottom: var(--gap-s);
	}
	.page-header__sub {
		color: var(--color-text-muted);
		font-size: var(--text-lg);
		max-width: 55ch;
	}

	/* Sale Pending — status callout */
	.status-callout {
		padding: var(--space-xl) 0 0;
		background: var(--color-bg);
		scroll-margin-top: 100px;
	}
	.status-callout__inner {
		max-width: 720px;
		border-left: 4px solid var(--color-accent);
		background: var(--color-bg-warm);
		padding: clamp(1.25rem, 3vw, 1.75rem) clamp(1.25rem, 3vw, 2rem);
		border-radius: 0 6px 6px 0;
	}
	.status-callout__badge {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		margin-bottom: 10px;
	}
	.status-callout__dot {
		width: 9px;
		height: 9px;
		border-radius: 50%;
		background: var(--color-accent);
		box-shadow: 0 0 0 4px rgba(14, 145, 140, 0.18);
		animation: status-pulse 2.4s ease-in-out infinite;
	}
	@keyframes status-pulse {
		0%, 100% { box-shadow: 0 0 0 4px rgba(14, 145, 140, 0.18); }
		50%      { box-shadow: 0 0 0 8px rgba(14, 145, 140, 0.05); }
	}
	@media (prefers-reduced-motion: reduce) {
		.status-callout__dot { animation: none; }
	}
	.status-callout__label {
		font-family: var(--font-body);
		font-size: 11px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 1.6px;
		color: var(--color-accent);
	}
	.status-callout__title {
		font-family: var(--font-display);
		font-size: clamp(1.5rem, 2.6vw, 2rem);
		font-weight: 600;
		color: var(--color-heading);
		margin: 0 0 var(--gap-s);
		line-height: 1.15;
		letter-spacing: -0.005em;
	}
	.status-callout__body {
		font-size: var(--text-md);
		line-height: 1.7;
		color: var(--color-text);
		margin: 0 0 var(--gap-s);
	}
	.status-callout__body:last-child { margin-bottom: 0; }
	.status-callout__body--soft {
		color: var(--color-text-muted);
		font-size: var(--text-sm);
	}
	.status-callout__body a {
		color: var(--color-accent);
		text-decoration: underline;
		text-underline-offset: 3px;
		text-decoration-thickness: 1px;
	}

	/* Intro */
	.transaction-intro {
		padding: var(--space-3xl) 0 var(--space-xl);
	}
	.transaction-intro__inner {
		max-width: 720px;
	}
	.transaction-intro h2 {
		font-size: clamp(1.75rem, 2.8vw, 2.25rem);
		font-weight: 600;
		margin: 0 0 var(--gap-m);
		letter-spacing: -0.005em;
	}
	.transaction-intro .prose :global(p) {
		font-size: var(--text-md);
		line-height: 1.75;
		color: var(--color-text);
	}

	/* Timeline */
	.timeline-section {
		padding-bottom: var(--space-3xl);
	}

	.timeline {
		--track-left: 24px;
		--progress: 0%;
		list-style: none;
		margin: 0;
		padding: 0;
		position: relative;
		max-width: 820px;
	}

	/* Gray track — stops at the last dot's center, not at the bottom of the list */
	.timeline::before {
		content: '';
		position: absolute;
		left: var(--track-left);
		top: 24px;
		height: var(--line-length, calc(100% - 48px));
		width: 2px;
		background: var(--color-border-light);
		transform: translateX(-50%);
	}

	/* Teal fill grows with scroll progress, capped at the last dot */
	.timeline::after {
		content: '';
		position: absolute;
		left: var(--track-left);
		top: 24px;
		width: 2px;
		height: min(var(--progress), var(--line-length, 100%));
		background: var(--color-accent);
		transform: translateX(-50%);
		transition: height 0.15s linear;
	}

	.timeline__step {
		position: relative;
		padding-left: calc(var(--track-left) + 40px);
		padding-bottom: var(--size-10);
	}
	.timeline__step:last-child {
		padding-bottom: 0;
	}

	.timeline__marker {
		position: absolute;
		left: var(--track-left);
		top: 0;
		z-index: 2;
		transform: translateX(-50%);
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.timeline__dot {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 48px;
		height: 48px;
		border-radius: 50%;
		background: var(--color-bg);
		border: 2px solid var(--color-border-light);
		color: var(--color-text-muted);
		font-family: var(--font-body);
		font-weight: 600;
		font-size: 1rem;
		transition: background 0.25s, border-color 0.25s, color 0.25s, transform 0.25s;
	}

	.timeline__step.is-reached .timeline__dot {
		background: var(--color-accent);
		border-color: var(--color-accent);
		color: #fff;
	}
	.timeline__step.is-active .timeline__dot {
		transform: scale(1.08);
		box-shadow: 0 0 0 6px rgba(14, 145, 140, 0.12);
	}

	.timeline__card {
		padding: 4px 0 0;
	}

	.timeline__title {
		font-size: clamp(1.2rem, 2vw, 1.5rem);
		font-weight: 600;
		margin: 0 0 var(--gap-s);
		color: var(--color-heading);
	}

	.timeline__card .prose :global(p) {
		font-size: var(--text-md);
		line-height: 1.7;
		color: var(--color-text);
		margin: 0 0 var(--gap-s);
		max-width: 65ch;
	}
	.timeline__card .prose :global(p:last-child) { margin-bottom: 0; }

	/* Outro — Why FSBO, Questions */
	.transaction-outro {
		padding: var(--space-2xl) 0 var(--space-3xl);
		background: var(--color-bg-warm);
	}
	.transaction-outro__wrap {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: clamp(var(--gap-l), 5vw, 72px);
	}
	.transaction-outro h2 {
		font-size: clamp(1.35rem, 2.2vw, 1.75rem);
		font-weight: 600;
		margin: 0 0 var(--gap-s);
	}
	.transaction-outro .prose :global(p) {
		font-size: var(--text-md);
		line-height: 1.75;
		color: var(--color-text);
		margin: 0 0 var(--gap-s);
	}

	/* Items that embed a forms grid go full-width across the 2-col layout. */
	.transaction-outro__item--full {
		grid-column: 1 / -1;
	}
	/* Lift the global .prose 65ch cap so the cards can use the full row. */
	.transaction-outro__item--full .prose {
		max-width: none;
	}

	.transaction-outro :global(.forms-grid) {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--gap-m);
		margin: var(--gap-m) 0;
	}
	.transaction-outro :global(.forms-card) {
		background: #fff;
		border: 1px solid var(--color-border-light);
		border-radius: 8px;
		padding: clamp(1rem, 2.4vw, 1.5rem);
	}
	.transaction-outro :global(.forms-card h4) {
		font-family: var(--font-body);
		font-size: var(--text-xs);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 1.5px;
		color: var(--color-accent);
		margin: 0 0 var(--gap-s);
	}
	.transaction-outro :global(.forms-card ul) {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.transaction-outro :global(.forms-card li) {
		padding: 5px 0;
		border-bottom: 1px solid var(--color-border-light);
		font-size: var(--text-sm);
	}
	.transaction-outro :global(.forms-card li:last-child) {
		border-bottom: none;
	}
	.transaction-outro :global(.forms-card a) {
		color: var(--color-heading);
		text-decoration: none;
		display: inline-flex;
		align-items: center;
		gap: 6px;
		transition: color 0.15s;
	}
	.transaction-outro :global(.forms-card a::before) {
		content: "↗";
		font-size: 0.85em;
		color: var(--color-accent);
	}
	.transaction-outro :global(.forms-card a:hover) {
		color: var(--color-accent);
	}

	@media (max-width: 900px) {
		.transaction-outro :global(.forms-grid) {
			grid-template-columns: 1fr;
		}
	}

	/* CTA */
	.cta {
		background: var(--color-bg-dark);
		padding: var(--size-12) 0;
	}
	.cta__inner { text-align: center; }
	.cta__inner h2 {
		color: #fff;
		font-weight: 600;
		margin-bottom: var(--gap-s);
	}
	.cta__inner p {
		color: rgba(255,255,255,0.5);
		font-size: var(--text-md);
		max-width: 45ch;
		margin: 0 auto var(--gap-m);
	}

	@media (max-width: 720px) {
		.transaction-outro__wrap { grid-template-columns: 1fr; }
	}
	@media (max-width: 600px) {
		.wrap { padding-left: var(--gap-m); padding-right: var(--gap-m); }
		.page-header { padding-top: clamp(80px, 14vw, 120px); }
		.timeline { --track-left: 18px; }
		.timeline__dot { width: 40px; height: 40px; font-size: 0.9rem; }
		.timeline__step { padding-left: calc(var(--track-left) + 30px); }
	}
</style>

<script>
	// Scroll-linked timeline progress: teal line fills in, dots go active/reached.
	const timeline = document.getElementById('timeline');
	if (timeline) {
		const steps = Array.from(timeline.querySelectorAll('.timeline__step')) as HTMLElement[];
		const markers = steps.map((s) => s.querySelector('.timeline__marker') as HTMLElement);

		function update() {
			const midpoint = window.innerHeight * 0.55;
			const rect = timeline.getBoundingClientRect();
			const firstMarker = markers[0].getBoundingClientRect();
			const lastMarker = markers[markers.length - 1].getBoundingClientRect();

			// Track length: from first marker center to last marker center.
			const trackTop = firstMarker.top + firstMarker.height / 2;
			const trackBottom = lastMarker.top + lastMarker.height / 2;
			const total = trackBottom - trackTop;
			timeline.style.setProperty('--line-length', `${total}px`);

			// Teal fill progress, capped at total.
			const scrolled = Math.max(0, Math.min(total, midpoint - trackTop));
			timeline.style.setProperty('--progress', `${scrolled}px`);

			// Active / reached step tracking
			let activeIdx = -1;
			steps.forEach((step, i) => {
				const m = markers[i].getBoundingClientRect();
				const center = m.top + m.height / 2;
				if (center <= midpoint) {
					step.classList.add('is-reached');
					activeIdx = i;
				} else {
					step.classList.remove('is-reached');
				}
				step.classList.remove('is-active');
			});
			if (activeIdx >= 0) steps[activeIdx].classList.add('is-active');
		}

		let raf = 0;
		function schedule() {
			if (raf) return;
			raf = requestAnimationFrame(() => {
				raf = 0;
				update();
			});
		}
		window.addEventListener('scroll', schedule, { passive: true });
		window.addEventListener('resize', schedule);
		update();
	}
</script>
