---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { marked } from 'marked';

const md = (s?: string) => s ? marked.parseInline(s, { async: false }) as string : '';

import heroBow from '../assets/home/hero-bow-edited.webp';
import kidsCockpit from '../assets/home/kids-cockpit.webp';
import tropicaliaAnchor from '../assets/home/tropicalia-anchor.webp';
import galleyWide from '../assets/home/galley-wide.webp';
import masterCabinQueen from '../assets/home/master-cabin-queen.webp';
import interior1 from '../assets/home/interior-1.webp';

const allPages = await getCollection('pages');
const homepage = allPages.find((p) => p.id === 'homepage');

const hero = homepage?.data.hero;
const glance = homepage?.data.glance;
const whyChose = homepage?.data.whyChose;
const upgradesSection = homepage?.data.upgradesSection;
const highlights = homepage?.data.highlights;
const bottomCta = homepage?.data.bottomCta;
const alternatingSections = homepage?.data.alternatingSections ?? [];
const topPhotos = homepage?.data.topPhotos ?? [];

const title = 'Voyage 500 Catamaran For Sale by Owner';
const description = homepage?.data.description ?? '';
---

<BaseLayout title={title} description={description}>

	<!-- HERO — split screen -->
	<section class="hero">
		<div class="hero__text">
			<div class="hero__text-inner">
				<p class="eyebrow">{hero?.eyebrow}</p>
				<h1>{(hero?.headlineLines ?? ['Voyage 500', 'Catamaran', 'For Sale']).map((line: string, i: number, arr: string[]) => (
					<>{line}{i < arr.length - 1 && <br />}</>
				))}</h1>
				<p class="hero__sub">{glance?.priceDisplay}<br />{glance?.locationDisplay}</p>
				<a href={hero?.ctaLink ?? '/contact/'} class="btn btn--primary">{hero?.ctaText ?? 'Inquire About This Boat'}</a>
			</div>
		</div>
		<div class="hero__image">
			<Image
				src={heroBow}
				alt="Tropicalia — Voyage 500 catamaran bow in turquoise Caribbean water"
				widths={[480, 720, 960, 1280, 1600]}
				sizes="(min-width: 900px) 50vw, 100vw"
				loading="eager"
				fetchpriority="high"
				decoding="async"
			 quality={68}/>
		</div>
	</section>

	<!-- AT A GLANCE -->
	<section class="glance">
		<div class="wrap">
			<div class="glance__grid">
				{(glance?.items ?? []).map((item: { label: string; value: string }) => (
					<div class="glance__item">
						<span class="glance__label">{item.label}</span>
						<span class="glance__value">{item.value}</span>
					</div>
				))}
			</div>
			{(glance?.note || glance?.linkText) && (
				<div class="glance__footer">
					{glance?.note && <p class="glance__note">{glance.note}</p>}
					{glance?.linkText && glance?.linkUrl && (
						<div class="glance__links">
							<a href={glance.linkUrl}>{glance.linkText} →</a>
						</div>
					)}
				</div>
			)}
		</div>
	</section>

	<!-- PHOTOS -->
	<section class="photos">
		<div class="photos__grid">
			{topPhotos.map((photo: { image: string; alt: string }, i: number) => (
				<div class:list={['photos__item', { 'photos__item--wide': i === 0 }]} data-photo-idx={i}>
					<img src={photo.image} alt={photo.alt} loading="lazy" />
				</div>
			))}
		</div>
		<div class="photos__footer">
			<a href="/gallery/" class="photos__more">View More Photos →</a>
		</div>
		<!-- Photo lightbox -->
		<dialog class="lightbox" id="photo-lightbox">
			<button class="lightbox__close" aria-label="Close">
				<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
			</button>
			<button class="lightbox__prev" aria-label="Previous">
				<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
			</button>
			<button class="lightbox__next" aria-label="Next">
				<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 6 15 12 9 18"/></svg>
			</button>
			<div class="lightbox__img-wrap">
				<img class="lightbox__img" src="" alt="" />
			</div>
			<div class="lightbox__counter"></div>
		</dialog>
	</section>

	<!-- WHY WE CHOSE THIS BOAT — intro -->
	<section class="features-intro">
		<div class="wrap">
			<div class="features-intro__grid">
				<div class="features-intro__text">
					<p class="eyebrow">{whyChose?.eyebrow}</p>
					<h2>{whyChose?.heading}</h2>
					<p set:html={md(whyChose?.body)}></p>
				</div>
				<div class="features-intro__photo">
					<Image src={kidsCockpit} alt="Our family aboard Tropicalia" widths={[480, 720, 960, 1280]} sizes="(min-width: 900px) 50vw, 100vw" loading="lazy"  quality={68}/>
				</div>
			</div>
		</div>
	</section>

	<!-- ALTERNATING STORY SECTIONS — full-bleed -->
	{alternatingSections.map((section: { eyebrow: string; heading: string; body: string; image: string }, i: number) => (
		<section class:list={['feat-row', { 'feat-row--reverse': i % 2 === 1 }]}>
			<div class="feat-row__image">
				{section.image && <img src={section.image} alt={section.heading} loading="lazy" />}
			</div>
			<div class="feat-row__content">
				<div class="feat-row__inner">
					<span class="card__cat">{section.eyebrow}</span>
					<h3>{section.heading}</h3>
					<p set:html={md(section.body)}></p>
				</div>
			</div>
		</section>
	))}

	<section class="features-cta">
		<div class="wrap" style="text-align: center; padding-top: var(--gap-l); padding-bottom: var(--gap-l);">
			<a href="/features/" class="btn btn--outline">View All Features &amp; Systems</a>
		</div>
	</section>

	<!-- RECENT UPGRADES — dark -->
	{upgradesSection?.items && upgradesSection.items.length > 0 && (
		<section class="upgrades">
			<div class="wrap">
				<p class="upgrades__eyebrow">{upgradesSection.eyebrow}</p>
				<h2 class="upgrades__heading">{upgradesSection.heading}</h2>
				<div class="upgrades__grid">
					{upgradesSection.items.map((item: { title: string; body: string }) => (
						<div class="upgrades__item">
							<svg class="upgrades__icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="20 6 9 17 4 12"/></svg>
							<h3>{item.title}</h3>
							<p set:html={md(item.body)}></p>
						</div>
					))}
				</div>
			</div>
		</section>
	)}

	<!-- BOTTOM PHOTO STRIP -->
	<section class="bottom-photos">
		<div class="wrap">
			<div class="bottom-photos__grid">
				<div class="bottom-photos__item">
					<Image src={tropicaliaAnchor} alt="Tropicalia at anchor in the US Virgin Islands" widths={[720, 1080, 1280]} sizes="(min-width: 1280px) 1200px, 100vw" loading="lazy" quality={72}/>
				</div>
				<div class="bottom-photos__item">
					<Image src={galleyWide} alt="U-shaped galley with bar seating" widths={[720, 1080, 1280]} sizes="(min-width: 1280px) 1200px, 100vw" loading="lazy" quality={72}/>
				</div>
				<div class="bottom-photos__item">
					<Image src={masterCabinQueen} alt="Owner's cabin with queen berth" widths={[720, 1080, 1280]} sizes="(min-width: 1280px) 1200px, 100vw" loading="lazy" quality={72}/>
				</div>
				<div class="bottom-photos__item">
					<Image src={interior1} alt="Salon interior" widths={[720, 1080, 1280]} sizes="(min-width: 1280px) 1200px, 100vw" loading="lazy" quality={72}/>
				</div>
			</div>
			<div class="bottom-photos__footer">
				<a href="/gallery/" class="bottom-photos__more">View More Photos →</a>
			</div>
		</div>
	</section>

	<!-- KEY EQUIPMENT — what cruisers look for -->
	{highlights?.bullets && (
		<section class="highlights">
			<div class="wrap">
				<div class="highlights__header">
					<p class="eyebrow">{highlights.eyebrow ?? 'Cruise-Ready'}</p>
					<h2>{highlights.heading ?? 'Key Equipment'}</h2>
				</div>
				<div class="highlights__grid">
					{highlights.bullets.map((bullet: string) => (
						<div class="highlights__item">
							<svg class="highlights__check" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
							<span>{bullet}</span>
						</div>
					))}
				</div>
			</div>
		</section>
	)}

	<!-- CTA — dark -->
	<section class="cta">
		<div class="wrap cta__inner">
			<h2>{bottomCta?.headline ?? 'Buy Direct from the Owner'}</h2>
			<p set:html={md(bottomCta?.body)}></p>
			<div class="cta__buttons">
				<a href={bottomCta?.primaryLink ?? '/contact/'} class="btn btn--primary">{bottomCta?.primaryText ?? 'Get in Touch'}</a>
				<a href={bottomCta?.secondaryLink ?? '/transaction/'} class="btn btn--outline cta__outline">{bottomCta?.secondaryText ?? 'How Does a FSBO Sale Work?'}</a>
			</div>
		</div>
	</section>

</BaseLayout>

<style>
	/* =============================================
	   LAYOUT
	   ============================================= */
	.wrap {
		max-width: 1280px;
		margin: 0 auto;
		padding-left: var(--gap-l);
		padding-right: var(--gap-l);
	}

	/* =============================================
	   HERO — split screen
	   ============================================= */
	.hero {
		display: grid;
		grid-template-columns: 1fr 1fr;
		min-height: 100vh;
		max-height: 960px;
	}

	.hero__text {
		display: flex;
		align-items: center;
		padding: var(--size-12) var(--gap-l);
		background: var(--color-bg);
	}

	.hero__text-inner {
		max-width: 480px;
	}

	.hero__text h1 {
		font-size: clamp(2.8rem, 4.5vw, 4.2rem);
		font-weight: 600;
		line-height: 1;
		letter-spacing: -1px;
		margin: var(--gap-s) 0 var(--gap-m);
	}

	.hero__sub {
		font-size: var(--text-md);
		color: var(--color-text-muted);
		line-height: 1.6;
		margin-bottom: var(--gap-m);
	}

	.hero__image {
		overflow: hidden;
		position: relative;
	}

	.hero__image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	/* =============================================
	   AT A GLANCE
	   ============================================= */
	.glance {
		padding: var(--size-10) 0;
		background: var(--color-bg-warm);
	}

	.glance__grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		column-gap: var(--gap-l);
		row-gap: 0;
	}

	.glance__item {
		padding: var(--size-4) 0;
		border-bottom: 1px solid var(--color-border);
	}

	/* Last row: no bottom border */
	.glance__item:nth-last-child(-n+4) {
		border-bottom: none;
	}

	/* Single-column mobile: restore bottom border on every item except the last */
	.glance__label {
		display: block;
		font-family: var(--font-body);
		font-size: 0.7rem;
		font-weight: 600;
		color: var(--color-text-muted);
		text-transform: uppercase;
		letter-spacing: 1.5px;
		margin-bottom: 8px;
	}

	.glance__value {
		display: block;
		font-family: var(--font-body);
		font-size: 1.0625rem;
		font-weight: 600;
		color: var(--color-heading);
		line-height: 1.4;
		font-variant-numeric: tabular-nums;
		letter-spacing: -0.005em;
	}

	.glance__footer {
		margin-top: var(--gap-l);
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		gap: var(--gap-l);
	}

	.glance__note {
		font-size: var(--text-sm);
		color: var(--color-text-muted);
		line-height: 1.6;
		max-width: 55ch;
		margin: 0;
	}

	.glance__links {
		display: flex;
		gap: var(--gap-m);
		flex-shrink: 0;
	}

	.glance__links a {
		font-size: var(--text-sm);
		font-weight: 600;
		color: var(--color-accent);
		white-space: nowrap;
	}

	/* =============================================
	   PHOTOS
	   ============================================= */
	.photos {
		padding: 0;
	}

	.photos__grid {
		display: grid;
		grid-template-columns: 1.2fr 1fr 1fr;
		gap: 2px;
	}

	.photos__item {
		overflow: hidden;
	}

	.photos__item img {
		width: 100%;
		height: 380px;
		object-fit: cover;
		transition: transform 0.5s var(--ease);
	}

	.photos__item {
		cursor: pointer;
	}

	.photos__item:hover img {
		transform: scale(1.03);
	}

	.photos__footer {
		text-align: right;
		padding: var(--gap-s) var(--gap-l) 0;
	}

	.photos__more {
		font-size: var(--text-sm);
		font-weight: 600;
		color: var(--color-accent);
	}

	/* Lightbox */
	.lightbox {
		border: none;
		background: rgba(0,0,0,0.95);
		padding: 0;
		max-width: 100vw;
		max-height: 100vh;
		z-index: 200;
	}

	.lightbox[open] {
		position: fixed;
		inset: 0;
		width: 100vw;
		height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.lightbox::backdrop { background: rgba(0,0,0,0.95); }

	.lightbox__img-wrap {
		max-width: 90vw;
		max-height: 85vh;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.lightbox__img {
		max-width: 100%;
		max-height: 85vh;
		object-fit: contain;
	}

	.lightbox__close,
	.lightbox__prev,
	.lightbox__next {
		position: fixed;
		z-index: 10;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(255,255,255,0.1);
		border: none;
		border-radius: 50%;
		cursor: pointer;
		color: #fff;
		transition: background 0.2s;
	}

	.lightbox__close { top: var(--gap-m); right: var(--gap-m); width: 44px; height: 44px; }
	.lightbox__prev, .lightbox__next { top: 50%; transform: translateY(-50%); width: 48px; height: 48px; }
	.lightbox__prev { left: var(--gap-m); }
	.lightbox__next { right: var(--gap-m); }
	.lightbox__close:hover, .lightbox__prev:hover, .lightbox__next:hover { background: rgba(255,255,255,0.2); }

	.lightbox__counter {
		position: fixed;
		top: var(--gap-m);
		left: var(--gap-m);
		color: rgba(255,255,255,0.5);
		font-size: var(--text-sm);
		font-weight: 500;
	}

	/* =============================================
	   FEATURES INTRO — warm bg
	   ============================================= */
	.features-intro {
		padding: var(--size-11) 0;
		background: var(--color-bg-warm);
	}

	.features-intro__grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--gap-l);
		align-items: center;
	}

	.features-intro__text h2 {
		font-size: clamp(2rem, 3vw, 2.6rem);
		font-weight: 600;
		margin: var(--gap-s) 0 var(--gap-m);
	}

	.features-intro__text p {
		font-size: var(--text-md);
		color: var(--color-text-muted);
		line-height: 1.75;
		max-width: 45ch;
	}

	.features-intro__photo {
		overflow: hidden;
	}

	.features-intro__photo img {
		width: 100%;
		aspect-ratio: 4/3;
		object-fit: cover;
	}

	/* =============================================
	   FEATURED ROWS — full-bleed alternating
	   ============================================= */
	.feat-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		min-height: 500px;
	}

	.feat-row--reverse {
		direction: rtl;
	}

	.feat-row--reverse > * {
		direction: ltr;
	}

	.feat-row__image {
		overflow: hidden;
	}

	.feat-row__image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s var(--ease);
	}

	.feat-row:hover .feat-row__image img {
		transform: scale(1.03);
	}

	.feat-row__content {
		display: flex;
		align-items: center;
		padding: var(--size-11) var(--gap-l);
	}

	.feat-row--reverse .feat-row__content {
		justify-content: flex-end;
	}

	.feat-row__inner {
		max-width: 480px;
	}

	.feat-row__inner h3 {
		font-size: clamp(1.8rem, 2.5vw, 2.4rem);
		font-weight: 600;
		margin: var(--gap-s) 0 var(--gap-m);
		line-height: 1.15;
	}

	.feat-row__inner p {
		font-size: var(--text-md);
		color: var(--color-text-muted);
		line-height: 1.7;
		margin-bottom: var(--gap-m);
	}

	.card__cat {
		font-size: var(--text-xs);
		font-weight: 500;
		color: var(--color-text-muted);
		text-transform: uppercase;
		letter-spacing: 1px;
	}

	.card__more {
		font-size: var(--text-sm);
		font-weight: 600;
		color: var(--color-accent);
		text-decoration: none;
	}

	.features-cta {
		background: var(--color-bg-warm);
	}

	/* =============================================
	   UPGRADES — dark
	   ============================================= */
	.upgrades {
		background: var(--color-bg-dark);
		padding: var(--size-11) 0;
	}

	.upgrades__eyebrow {
		font-family: var(--font-body);
		font-size: var(--text-xs);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 2.5px;
		color: var(--color-accent-light);
		margin-bottom: var(--gap-s);
	}

	.upgrades__heading {
		color: #fff;
		font-weight: 600;
		margin-bottom: var(--gap-l);
	}

	.upgrades__grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--gap-l);
	}

	.upgrades__icon {
		color: var(--color-accent-light);
		margin-bottom: var(--gap-s);
	}

	.upgrades__item h3 {
		font-size: var(--text-xl);
		font-weight: 600;
		color: #fff;
		margin-bottom: 6px;
	}

	.upgrades__item p {
		font-size: var(--text-sm);
		color: rgba(255,255,255,0.45);
		line-height: 1.6;
		margin: 0;
	}

	/* =============================================
	   HIGHLIGHTS
	   ============================================= */
	.highlights {
		padding: var(--size-11) 0;
	}

	.highlights__header h2 {
		font-weight: 600;
		margin-top: var(--gap-s);
		margin-bottom: var(--gap-l);
	}

	.highlights__grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--gap-s) var(--gap-l);
	}

	.highlights__item {
		display: flex;
		align-items: flex-start;
		gap: 10px;
		padding: 14px 0;
		border-bottom: 1px solid var(--color-border-light);
		font-size: var(--text-sm);
		color: var(--color-text);
		line-height: 1.5;
	}

	.highlights__check {
		color: var(--color-accent);
		flex-shrink: 0;
		margin-top: 1px;
	}

	/* =============================================
	   BOTTOM PHOTO STRIP
	   ============================================= */
	.bottom-photos {
		padding: var(--size-11) 0;
		background: var(--color-bg-warm);
	}

	.bottom-photos__grid {
		display: flex;
		flex-direction: column;
		gap: var(--gap-m);
	}

	.bottom-photos__item {
		overflow: hidden;
	}

	.bottom-photos__item img {
		width: 100%;
		height: auto;
		display: block;
		transition: transform 0.5s var(--ease);
	}

	.bottom-photos__item:hover img {
		transform: scale(1.03);
	}

	.bottom-photos__footer {
		text-align: right;
		padding-top: var(--gap-m);
	}

	.bottom-photos__more {
		font-size: var(--text-sm);
		font-weight: 600;
		color: var(--color-accent);
	}

	/* =============================================
	   CTA — dark
	   ============================================= */
	.cta {
		background: var(--color-bg-dark);
		padding: var(--size-12) 0;
	}

	.cta__inner {
		text-align: center;
	}

	.cta__inner h2 {
		font-size: clamp(2.5rem, 4.5vw, 3.8rem);
		font-weight: 600;
		color: #fff;
		line-height: 1.05;
		margin-bottom: var(--space-md);
	}

	.cta__inner p {
		color: rgba(255,255,255,0.4);
		font-size: var(--text-md);
		max-width: 42ch;
		margin: 0 auto var(--space-xl);
	}

	.cta__buttons {
		display: flex;
		gap: var(--space-sm);
		justify-content: center;
	}

	.cta__outline {
		border-color: rgba(255,255,255,0.2);
		color: rgba(255,255,255,0.7);
	}

	.cta__outline:hover {
		background: #fff;
		color: var(--color-heading);
		border-color: #fff;
	}

	/* =============================================
	   RESPONSIVE
	   ============================================= */
	@media (max-width: 900px) {
		.hero { grid-template-columns: 1fr; max-height: none; min-height: auto; }
		.hero__text { padding: var(--size-12) var(--gap-m) var(--gap-l); }
